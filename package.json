{
  "name": "roost",
  "private": true,
  "workspaces": {
    "packages": ["packages/*", "apps/*", "examples/*"],
    "catalog": {
      "typescript": "^5.8.0",
      "bun-types": "latest",
      "@cloudflare/workers-types": "^4.20250409.0",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "@tanstack/react-start": "1.167.42",
      "@tanstack/react-router": "1.168.23",
      "vite": "7.3.2",
      "vite-tsconfig-paths": "5.1.4",
      "@vitejs/plugin-react": "5.1.4",
      "@cloudflare/vite-plugin": "1.33.1",
      "wrangler": "4.84.1",
      "drizzle-orm": "^0.44.0",
      "drizzle-kit": "^0.30.0",
      "@faker-js/faker": "^9.0.0"
    }
  },
  "scripts": {
    "build": "bun run --filter '@roostjs/*' build",
    "changeset": "changeset",
    "changeset:check": "changeset status --since=origin/main",
    "demo:local-registry": "bun run scripts/local-registry-demo.ts",
    "prepare:publish": "bun run scripts/prepare-publish.ts",
    "release:preview": "bun run prepare:publish && bun run scripts/preview-publish.ts",
    "release:publish": "bun run prepare:publish && bun run scripts/publish-packages.ts",
    "test": "bun test",
    "typecheck": "bun run --filter '@roostjs/*' typecheck",
    "version:packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
